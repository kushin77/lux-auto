### Resource Monitoring Dashboard

Tracks system resources like disk, memory, CPU, and connections.

```json
{
  "id": "resource-monitoring",
  "title": "Resource Monitoring",
  "type": "resources",
  "refreshInterval": 30,
  "sections": [
    {
      "id": "database-metrics",
      "title": "Database Metrics",
      "metrics": [
        {
          "name": "Connection Pool Usage",
          "query": "SELECT count(*) FROM pg_stat_activity;",
          "threshold": {
            "warning": 30,
            "critical": 40
          },
          "unit": "connections"
        },
        {
          "name": "Active Queries",
          "query": "SELECT count(*) FROM pg_stat_activity WHERE state='active';",
          "unit": "queries"
        },
        {
          "name": "Database Size",
          "query": "SELECT pg_database_size('lux_prod') / 1024.0 / 1024.0;",
          "unit": "MB",
          "threshold": {
            "warning": 25000,
            "critical": 40000
          }
        },
        {
          "name": "Slow Queries",
          "query": "SELECT count(*) FROM pg_stat_statements WHERE mean_time > 1000;",
          "unit": "queries",
          "threshold": {
            "warning": 5,
            "critical": 10
          }
        },
        {
          "name": "Table Bloat",
          "query": "SELECT count(*) FROM pg_stat_user_tables WHERE n_tup_dead > 1000;",
          "unit": "tables",
          "threshold": {
            "warning": 2,
            "critical": 5
          }
        }
      ]
    },
    {
      "id": "cache-metrics",
      "title": "Cache Metrics",
      "metrics": [
        {
          "name": "Memory Usage",
          "query": "INFO memory",
          "unit": "%",
          "threshold": {
            "warning": 75,
            "critical": 90
          }
        },
        {
          "name": "Hit Rate",
          "query": "INFO stats",
          "unit": "%",
          "threshold": {
            "warning": 70,
            "critical": 50
          }
        },
        {
          "name": "Evictions",
          "query": "INFO stats",
          "unit": "keys/second",
          "threshold": {
            "warning": 100,
            "critical": 500
          }
        }
      ]
    },
    {
      "id": "container-metrics",
      "title": "Container Metrics",
      "metrics": [
        {
          "name": "CPU Usage",
          "source": "docker stats",
          "unit": "%",
          "threshold": {
            "warning": 70,
            "critical": 85
          }
        },
        {
          "name": "Memory Usage",
          "source": "docker stats",
          "unit": "%",
          "threshold": {
            "warning": 75,
            "critical": 90
          }
        },
        {
          "name": "Disk I/O",
          "source": "docker stats",
          "unit": "MB/s"
        },
        {
          "name": "Container Restarts",
          "source": "docker inspect",
          "unit": "count",
          "threshold": {
            "warning": 1,
            "critical": 3
          }
        }
      ]
    }
  ]
}
```

