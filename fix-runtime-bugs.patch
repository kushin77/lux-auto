From 39193dc39c4125311185889fdee4935d1c17051a Mon Sep 17 00:00:00 2001
From: Alex Kushnir <kushin77@gmail.com>
Date: Sun, 14 Jun 2026 19:58:39 -0400
Subject: [PATCH] fix: resolve 7 runtime bugs across backend

- models.py: alias UserRole enum import as UserRoleEnum to avoid name
  collision with the UserRole ORM model class defined in same file
- main.py: fix get_or_create_user arg order (was passing db as email) in
  all 3 call sites (/api/me, /api/sessions/logout-all, /api/sessions)
- main.py: fix revoke_all_user_sessions arg order (user_id must come first)
- main.py: rename get_active_sessions -> list_user_sessions with correct
  arg order to match SessionService method signature
- main.py: fix /metrics endpoint to return Response with Prometheus
  CONTENT_TYPE_LATEST instead of JSONResponse (which would double-encode)
- deals.py: rename query param status -> deal_status (alias='status') to
  prevent shadowing the imported fastapi.status module inside list_deals()
- analytics.py: same fix for list_buyers() buyer_status param
---
 backend/database/models.py   |  4 ++--
 backend/main.py              | 21 +++++++++------------
 backend/routers/analytics.py |  2 +-
 backend/routers/deals.py     |  2 +-
 4 files changed, 13 insertions(+), 16 deletions(-)

diff --git a/backend/database/models.py b/backend/database/models.py
index ce4a4db..e7fa91b 100644
--- a/backend/database/models.py
+++ b/backend/database/models.py
@@ -17,7 +17,7 @@ from sqlalchemy import Column, Integer, String, Boolean, DateTime, Enum, Text, F
 from sqlalchemy.ext.declarative import declarative_base
 from sqlalchemy.orm import relationship
 from datetime import datetime
-from backend.auth.user_service import UserRole
+from backend.auth.user_service import UserRole as UserRoleEnum
 
 Base = declarative_base()
 
@@ -30,7 +30,7 @@ class User(Base):
     id = Column(Integer, primary_key=True, index=True)
     email = Column(String(255), unique=True, index=True, nullable=False)
     name = Column(String(255), nullable=True)
-    role = Column(Enum(UserRole), default=UserRole.USER, nullable=False)
+    role = Column(Enum(UserRoleEnum), default=UserRoleEnum.USER, nullable=False)
     active = Column(Boolean, default=True, nullable=False)
     created_at = Column(DateTime, default=datetime.utcnow, nullable=False)
     last_login = Column(DateTime, default=datetime.utcnow, nullable=False)
diff --git a/backend/main.py b/backend/main.py
