# Lux-Auto backend — environment. Copy to backend/.env (gitignored).

# ── Database (Cloud SQL Postgres in prod; local Postgres in dev) ─────────
# Cloud Run + Cloud SQL connector form:
#   postgresql+psycopg2://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+psycopg2://luxauto:luxauto@localhost:5432/luxauto

# ── Security ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
FASTAPI_SECRET_KEY=

# First-login admin (gets ADMIN role automatically)
ADMIN_USER_EMAIL=alex@luxauto.com

# ── Runtime ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8080
