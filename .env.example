# Lux Auto — local development environment
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# ── Manheim API (developer.manheim.com) ─────────────────────────────────
# Mashery package key / secret from your Manheim developer app.
MANHEIM_CLIENT_ID=
MANHEIM_CLIENT_SECRET=

# Base host. Use the sandbox while developing, switch to prod for live.
#   Sandbox: https://sandbox.manheim.com
#   Prod:    https://api.manheim.com
MANHEIM_BASE_URL=https://api.manheim.com

# ── clasp / Apps Script ─────────────────────────────────────────────────
# The Script ID of your Apps Script project (Project Settings → IDs).
# Also goes in .clasp.json. Kept here so CI can inject it.
SCRIPT_ID=

# Optional: deployment ID for `npm run deploy` to update an existing web app
DEPLOYMENT_ID=

# ── Google Chat (optional alerts) ───────────────────────────────────────
# Set in Script Properties for the live app; here only for local CLI tests.
CHAT_WEBHOOK_URL=
