# Lux-Auto Environment Template
# DO NOT COMMIT ACTUAL VALUES - This is a template only
# Populate with real values from Google Secret Manager in production

## OAuth2 Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
OAUTH2_PROXY_COOKIE_SECRET=YOUR_COOKIE_SECRET_BASE64_HERE
OAUTH2_PROXY_COOKIE_EXPIRE=86400
OAUTH2_PROXY_COOKIE_REFRESH=3600
OAUTH2_PROXY_SESSION_STORE_TYPE=redis
OAUTH2_PROXY_REDIS_CONNECTION_URL=redis://cache:6379/0

## FastAPI Configuration
FASTAPI_SECRET_KEY=YOUR_FASTAPI_SECRET_KEY_BASE64_HERE
FASTAPI_DEBUG=false
FASTAPI_LOG_LEVEL=INFO

## Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=lux_prod
DATABASE_USER=lux_admin
DATABASE_PASSWORD=YOUR_DB_PASSWORD_HERE
DATABASE_URL=postgresql://lux_admin:YOUR_DB_PASSWORD_HERE@postgres:5432/lux_prod

## Admin User
ADMIN_USER_EMAIL=akushnir@bioenergystrategies.com

## Deployment Configuration
DOMAIN=lux.kushnir.cloud
ENVIRONMENT=production
DEPLOY_ENV=docker

## Google Secret Manager
GSM_PROJECT=lux-auto

## Certificate Configuration (Caddy)
ACME_EMAIL=akushnir@bioenergystrategies.com
ACME_CA=https://acme-v02.api.letsencrypt.org/directory

## Service Ports (Docker internal - not exposed)
FASTAPI_PORT=8000
OAUTH2_PROXY_PORT=4180
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
POSTGRES_PORT=5432
REDIS_PORT=6379
APPSMITH_PORT=8080
BACKSTAGE_PORT=3000

## Appsmith Portal Configuration
APPSMITH_DB_PASSWORD=YOUR_APPSMITH_DB_PASSWORD_HERE
APPSMITH_ENCRYPTION_PASSWORD=YOUR_APPSMITH_ENCRYPTION_PASSWORD_HERE
APPSMITH_ENCRYPTION_SALT=YOUR_APPSMITH_ENCRYPTION_SALT_BASE64_HERE

## Backstage Portal Configuration
BACKSTAGE_DB_PASSWORD=YOUR_BACKSTAGE_DB_PASSWORD_HERE
BACKSTAGE_GITHUB_TOKEN=YOUR_BACKSTAGE_GITHUB_TOKEN_HERE
BACKSTAGE_GITHUB_CLIENT_ID=YOUR_BACKSTAGE_GITHUB_CLIENT_ID_HERE
BACKSTAGE_GITHUB_CLIENT_SECRET=YOUR_BACKSTAGE_GITHUB_CLIENT_SECRET_HERE

## Monitoring & Observability
SENTRY_DSN=
LOG_FORMAT=json
ENABLE_METRICS=true
PROMETHEUS_PORT=9090

## Security
FORCE_HTTPS=true
SESSION_TTL=86400
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

## Development/Testing Only
# Uncomment to enable test mode
# TESTING=true
# LOG_LEVEL=DEBUG
